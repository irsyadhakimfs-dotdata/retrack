# Salin file ini menjadi .env dan isi nilainya

# Kunci rahasia Flask — ganti dengan string acak yang panjang di production
SECRET_KEY=ganti-dengan-secret-key-yang-kuat

# Environment: development | testing | production
FLASK_ENV=development

# URL database (untuk production, bisa pakai PostgreSQL)
# DATABASE_URL=sqlite:///refinance_dev.db

# Interval auto-refresh data market di sisi klien (jam); default 6
MARKET_REFRESH_HOURS=6

# Default periode tren laporan (bulan); rentang 1–6, default 2
TREND_DEFAULT_MONTHS=2
